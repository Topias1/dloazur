<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Browser">
            <directory>tests/Browser</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
<env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <!-- Honeypot: disable timestamp check in tests (valid_from would always fail in unit tests) -->
        <env name="HONEYPOT_SECONDS" value="0"/>
        <env name="HONEYPOT_VALID_FROM_TIMESTAMP" value="false"/>
        <!-- Honeypot: disable randomization so field name stays 'my_name' in tests -->
        <env name="HONEYPOT_RANDOMIZE" value="false"/>
        <!-- Blog source: keep file-backed path so existing BlogTest stays green
             while later waves flip the public read path to DB (Plan 06-03). -->
        <env name="BLOG_SOURCE" value="files"/>
        <!-- Worktree isolation: override APP_BASE_PATH so Laravel resolves views/routes
             from this worktree instead of the main repo (shared vendor symlink). -->
        <server name="APP_BASE_PATH" value="/Users/amnesia/dev/dloazur/.claude/worktrees/agent-a7c2b02cdc12fbc81"/>
    </php>
</phpunit>
